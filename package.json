{
  "name": "realtimechat",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "server": "turbo run dev --filter=@realtimechat/server",
    "web": "turbo run dev --filter=@realtimechat/web",
    "build": "turbo run build",
    "build:server": "turbo run build --filter=@realtimechat/server",
    "build:web": "turbo run build --filter=@realtimechat/web",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
